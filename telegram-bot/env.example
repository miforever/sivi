# Sivi Bot - Environment Variables
# Copy this file to .env and fill in your values

# Application
DEBUG=False
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8001

# Telegram
# REQUIRED - Get from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here
# Optional - Comma separated user IDs for admins
ADMIN_IDS=

# Payment
# REQUIRED - Get from @BotFather on Telegram (Click service)
CLICK_TOKEN=your_click_token_here

# Backend APIs
# REQUIRED - Your backend API URL (with trailing /api/ or /api/v1/)
BACKEND_URL=http://localhost:8000/api/
# REQUIRED - API key for backend authentication (from backend's API_KEYS)
BACKEND_API_KEY=your_backend_api_key_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Optional: REDIS_URL=redis://localhost:6379/0

# Webhook (required in production — bot always runs in webhook mode when deployed)
WEBHOOK_HOST=https://bot.sivi.uz
WEBHOOK_SECRET=your_webhook_secret_here  # openssl rand -hex 32
# WEBHOOK_PATH=/webhook  # default, no need to change

# Cache and Session (Optional)
USER_CACHE_TTL=3600
LANGUAGE_CACHE_TTL=3600
VACANCY_CACHE_TTL=1800
RESUME_ANSWERS_TTL=259200
RESUMES_CACHE_TTL=3600

# Rate Limiting
THROTTLE_RATE=3
THROTTLE_WINDOW=60

# File Upload / Limits
MAX_RESUME_SLOTS=3
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=.pdf,.doc,.docx