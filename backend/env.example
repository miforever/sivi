# Sivi Backend - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Core Settings
# =============================================================================
DEBUG=False
SECRET_KEY=your-super-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
LOG_LEVEL=INFO

# =============================================================================
# Database (PostgreSQL + pgvector)
# =============================================================================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=sivi
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Docker PostgreSQL init (if using docker-compose)
POSTGRES_DB=sivi
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379/2

# =============================================================================
# Security & Auth
# =============================================================================
# API Keys (comma-separated, must match BACKEND_API_KEY in telegram-bot/.env)
API_KEYS=key1,key2,key3

# SuperAdmin — Access for admin panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_password

# =============================================================================
# AI Services
# =============================================================================
# OpenAI (resume extraction & generation)
OPENAI_API_KEY=your-openai-api-key-here

# Embedding / Matching (Fireworks.ai)
FIREWORKS_API_KEY=your-fireworks-api-key-here
FIREWORKS_EMBEDDING_MODEL=WhereIsAI/UAE-Large-V1
EMBEDDING_DIMENSIONS=1024

# =============================================================================
# Telegram Scraper (Telethon) — Side account credentials
# =============================================================================
TELETHON_API_ID=your-telethon-api-id
TELETHON_API_HASH=your-telethon-api-hash
TELETHON_BOT_TOKEN=your-telethon-bot-token
TELETHON_SESSION=your-telethon-session-string

# =============================================================================
# File storage & Limits
# =============================================================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx
MAX_RESUMES_PER_USER=5

# AWS S3 (Optional - Set USE_S3=True to use)
USE_S3=False
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# =============================================================================
# Infrastructure
# =============================================================================
COMPOSE_FILE=docker-compose.yml:docker-compose.local.yml

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Sentry (Optional)
SENTRY_DSN=
